{
  "manifest_version": 3,
  "name": "Learning Agent - Canvas Sync",
  "version": "1.0.0",
  "description": "Sync your Canvas LMS courses, assignments, grades, and files to a local backend — powering AI-ready study tools.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications",
    "downloads"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content-scripts/detect.js", "content-scripts/canvas.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Learning Agent - Canvas Sync",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
